---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import SocialLinks from '../components/SocialLinks';
import ProjectCardCompact from '../components/ProjectCardCompact';
import OvalGlowBox from '../components/OvalGlowBox';
import ShiningText from '../components/ShiningText';
import { featuredProjects, projectCategories } from '../data/projects';

const posts = await getCollection('blog').then((posts) => 
  posts.slice(0, 5)
).catch((error) => {
  console.error(error);
  return [];
});
;
var options = { year: 'numeric', month: 'long', day: 'numeric' };

---

<Layout title="Seba Sepulveda | Data & AI Engineer">
  <div class="container mx-auto px-2">
    <div class="mx-auto py-16">
      <!-- Top section: Image (left) and Text (right) -->
      <div class="flex items-center gap-8">
        <!-- Image -->
        <div class="w-48 h-48 rounded-full overflow-hidden flex-shrink-0 border-2 border-dark-accent bg-gray-900">
          <img
            src="/me-avatar-color.jpeg"
            alt="Seba Sepulveda"
            class="block w-full h-full aspect-square rounded-full object-cover"
          />
        </div>

        <!-- Text -->
        <div class="text-left">
          <p class="text-sm font-medium text-yellow-400 uppercase tracking-wider mb-2">Data & AI Engineer</p>
          <h1 class="text-3xl font-normal mb-2">Hi, I'm Sebastian Sepulveda</h1>
          <SocialLinks 
            iconSize="w-6 h-6" spacing="space-x-4" color="text-gray-400 hover:text-gray-100"
          />
          <p class="text-lg text-gray-300 mb-3 max-w-2xl">
            I build data platforms, AI-assisted workflows and product experiments that turn messy operational problems into systems people can actually use.
            <ShiningText
              text="Follow the work in progress.">
            </ShiningText>
          </p>
        </div>
      </div>
      <!-- Buttons row: Centered -->
      <div class="flex justify-center gap-4 mt-8 flex-wrap">
        <a
          href="/blog"
          class="inline-block px-6 py-3 border border-gray-900 rounded-lg hover:bg-gray-300 hover:text-dark-bg transition-colors"
        >
          Read Blog
        </a>
        <a
          href="/projects"
          class="inline-block px-6 py-3 border border-gray-900 rounded-lg hover:bg-gray-300 hover:text-dark-bg transition-colors"
        >
          View Projects
        </a>
      </div>

      <h2 class="text-xl font-bold mb-6 mt-8">My latest posts</h2>
        <div class="mt-4">
          <ul class="space-y-4">
            {posts.map((post) => (
              <li>
                <a href={`blog/${post.slug}`} class="flex items-center justify-between transition-colors duration-300 hover:text-yellow-400">
                  <h3>{post.data.title}</h3>
                  <time class="text-gray-400 text-sm">{post.data.pubDate.toLocaleDateString("en-US", options)}</time>
                </a>
              </li>
            ))}
          </ul>
        </div>
      
      <!-- About me -->
      <div class="mt-12"> 
        <h2 class="text-xl font-bold mb-4">About Me</h2>
        <OvalGlowBox>
          <p class="text-gray-200 mb-4">
            My friends call me Seba. I am a <strong class="text-yellow-500">Data & AI Engineer</strong> from Chile, working where data engineering, automation and applied AI meet real product problems.
          </p>
          <p class="text-gray-200 mb-4">
            <strong class="text-yellow-400">Since June 2026 I have been working as a Data Engineer at Drimo - LATAM Airlines</strong>, building ETL processes and automations on GCP. Before that, I worked in retail and insurance, improving analytics workflows, cloud data pipelines and machine learning systems used by business teams.
          </p>
          <p class="text-gray-200 mb-4">
            I like building with a clear product angle: Nuku explores how families can keep health records under control, Dream Home makes Chilean home buying decisions easier to compare, and AI Memory Vault turns AI coding sessions into searchable engineering memory.
          </p>
          <p class="text-gray-200 mb-4">
            My research background is in <strong class="text-yellow-400">Vision AI for cultural heritage</strong>, including detection and segmentation of repetitive patterns in ancient Peruvian pottery. That work shaped how I think about applied AI: useful models need context, workflows and a way to be inspected by humans.
          </p>
          <p class="text-gray-200">
            This site is where I connect the dots between work, research and personal products. When I'm away from the keyboard, you can find me playing football, cooking or <a href="/photos/" class="hover:text-blue-300">taking photos</a>.
          </p>
        </OvalGlowBox>
      </div>

      <div class="mt-12">
        <!-- Projects -->
        <h2 class="text-xl font-bold mt-12 mb-4">Publications</h2>
        <div class="grid grid-cols-1 gap-8">
          <ul>
            <h3 class="text-xl font-semibold mb-2">2024</h3>
            <li>
              <ul class="list-disc pl-4">
                <li>
                  <b>
                  <a href="https://doi.org/10.1145/3694789" class="flex items-center justify-between transition-colors duration-300 text-gray-200 hover:text-red-500">
                    Repetitive Patterns Recognition in Textures of Ancient Peruvian Pottery
                  </a></b> 
                  <p class="text-gray-400">Sebastian Sepulveda, Benjamin Bustos, and Ivan Sipiran. 2024. ACM Journal on Computing and Cultural Heritage, Volume 17, 4, Article 55 (December 2024).</p>
                  </li>
                </ul>
            </li>
          </ul>
        </div>
      </div>

      <div class="mt-12">
        <h2 class="text-xl font-bold mt-12 mb-6">Projects</h2>

        {projectCategories.map((category) => {
          const categoryProjects = featuredProjects.filter((project) => project.category === category);

          if (categoryProjects.length === 0) {
            return null;
          }

          return (
            <div class="mb-8">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-emerald-400 text-lg">●</span>
                <h3 class="text-sm font-medium text-gray-400 uppercase tracking-wider">{category}</h3>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {categoryProjects.map((project) => (
                  <ProjectCardCompact
                    title={project.title}
                    description={project.description}
                    impact={project.impact}
                    icon={project.icon}
                    accentColor={project.accentColor}
                    status={project.status}
                    tags={project.tags}
                    href={project.href}
                  />
                ))}
              </div>
            </div>
          );
        })}

        <a href="/projects" class="inline-block text-sm text-gray-400 hover:text-yellow-400 transition-colors">
          View all projects -&gt;
        </a>
      </div>
      
    </div>
  </div>
</Layout>
