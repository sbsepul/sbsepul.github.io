---
import SocialLinks from '../components/SocialLinks';
import Layout from '../layouts/Layout.astro';

const email = 'sbsepul@gmail.com';
const cvRequestHref = `mailto:${email}?subject=${encodeURIComponent('Solicitud de CV - Sebastian Sepulveda')}&body=${encodeURIComponent('Hola Sebastian,\n\nMe gustaria solicitar tu CV actualizado.\n\nSaludos.')}`;
---

<Layout title="CV | Seba Sepulveda">
  <div class="container mx-auto px-4 max-w-3xl py-10 sm:py-16">
    <p class="text-sm font-medium text-yellow-400 uppercase tracking-wider mb-3">Data & AI Engineer</p>
    <h1 class="text-3xl sm:text-4xl font-bold mb-4">Request my CV</h1>
    <SocialLinks
      iconSize="w-6 h-6"
      spacing="space-x-4"
      color="text-gray-400 hover:text-gray-50"
    />
    <p class="text-gray-400 mb-8">Updated profile: July 2026</p>

    <section class="mb-10 border border-gray-800 rounded-lg p-4 sm:p-6 bg-gray-950/40">
      <p class="text-lg sm:text-xl text-gray-100 mb-4">
        I keep my full CV available by request so I can share the most relevant and up-to-date version for each opportunity.
      </p>
      <p class="text-gray-300 mb-6">
        I currently work as a Data Engineer at Drimo - LATAM Airlines, building ETL processes and automations on GCP with Dataform, Cloud Functions and BigQuery. My background includes data platforms, applied AI, computer vision research and product engineering.
      </p>
      <a
        href={cvRequestHref}
        class="inline-block px-6 py-3 border border-yellow-500 text-yellow-300 rounded-lg hover:bg-yellow-500 hover:text-gray-950 transition-colors"
      >
        Request CV by email
      </a>
      <p class="text-sm text-gray-500 mt-4">
        Email: <a href={`mailto:${email}`} class="hover:text-yellow-400">{email}</a>
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Profile snapshot</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-gray-300">
        <div class="border-l-2 border-gray-700 pl-4">
          <h3 class="font-semibold text-gray-100 mb-2">Core work</h3>
          <p>Data engineering, GCP automation, analytics workflows, AI-assisted development and production-oriented ML systems.</p>
        </div>
        <div class="border-l-2 border-gray-700 pl-4">
          <h3 class="font-semibold text-gray-100 mb-2">Public projects</h3>
          <p>Nuku, Dream Home, AI Memory Vault and Vision AI research for cultural heritage.</p>
        </div>
      </div>
    </section>

  </div>
</Layout>
