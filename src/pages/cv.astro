---
import SocialLinks from '../components/SocialLinks';
import Layout from '../layouts/Layout.astro';
---

<Layout title="CV | Seba Sepulveda">
  <div class="container mx-auto px-4 max-w-3xl py-16">
    <h1 class="text-4xl font-bold mb-4">Sebastian Sepulveda</h1>
    <!-- add icons with links -->
      <SocialLinks
      iconSize="w-6 h-6"
      spacing="space-x-4"
      color="text-gray-400 hover:text-gray-50"
    />
    <!-- Last updated -->
    <p class="text-gray-400 mb-8">Last updated: July 2026</p>

    <!-- Education -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Education</h2>
      <div class="border-l-2 border-gray-200 pl-4">
        <div class="mb-6">
          <!-- Top row with title & date -->
          <div class="flex justify-between">
            <div>
              <h3 class="text-xl font-semibold">M.Sc. in Data Science & Computer Science</h3>
              <p class="text-gray-300">University of Chile</p>
            </div>
            <!-- Date on the right -->
            <p class="text-gray-200">2022 - 2024</p>
          </div>

          <!-- Optional bullet points below -->
          <ul class="list-disc list-inside mt-2 text-gray-400">
            <li>Specializations in Machine Learning, Deep Learning, Big Data</li>
            <li>Graduated with honors, focusing on applied Vision AI research</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Experience</h2>
      <div class="border-l-2 border-gray-200 pl-4">

        <div class="mb-6">
          <!-- Top row with title & date -->
          <div class="flex justify-between gap-4">
            <div>
              <h3 class="text-xl font-semibold">Data Engineer</h3>
              <p class="text-gray-300">Drimo - LATAM Airlines</p>
            </div>
            <!-- Date on the right -->
            <p class="text-gray-200">June 2026 - Present</p>
          </div>

          <!-- Optional bullet points below -->
          <ul class="list-disc list-inside mt-2 text-gray-400">
            <li>Developing ETL processes and automations on Google Cloud Platform using Dataform, Cloud Functions and BigQuery.</li>
            <li>Building and improving data workflows for analytics and operational use cases in the airline domain.</li>
          </ul>
        </div>

        <div class="mb-6">
          <!-- Top row with title & date -->
          <div class="flex justify-between gap-4">
            <div>
              <h3 class="text-xl font-semibold">Data Engineer</h3>
              <p class="text-gray-300">Falabella Retail S.A.</p>
            </div>
            <!-- Date on the right -->
            <p class="text-gray-200">Aug 2022 - June 2026</p>
          </div>

          <!-- Optional bullet points below -->
          <ul class="list-disc list-inside mt-2 text-gray-400">
            <li>Developed and maintained production data pipelines for retail analytics workflows</li>
            <li>Implemented cloud-based data solutions using GCP</li>
            <li>Optimized BigQuery-based data processing workflows</li>
            <li>Collaborated with cross-functional teams to integrate and improve machine learning systems</li>
            <li>Prepared and led an internal workshop on Claude Code and Codex, covering harness engineering patterns, reusable skills, MCP integrations, and task delegation with agents and subagents.</li>
          </ul>
        </div>

      </div>
    </section>

    <!-- Skills -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Skills</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <h3 class="font-semibold mb-2">Programming Languages</h3>
          <ul class="list-disc list-inside text-gray-400">
            <li>Python</li>
            <li>TypeScript</li>
            <li>SQL</li>
            <li>Java</li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold mb-2">Technologies & Tools</h3>
          <ul class="list-disc list-inside text-gray-400">
            <li>GCP, BigQuery, Dataform, Cloud Functions, Spark</li>
            <li>Next.js, React, Tailwind CSS</li>
            <li>PostgreSQL, Prisma, Zod</li>
            <li>FastAPI, Docker, agent tooling</li>
            <li>TensorFlow, PyTorch, computer vision</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Interests -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Interests</h2>
      <ul class="list-disc list-inside text-gray-400 ml-4">
        <li>AI agents, developer tools and portable engineering memory</li>
        <li>Local-first products for health, finance and real estate</li>
        <li>Vision AI, cultural heritage and applied machine learning research</li>
      </ul>
    </section>

    <!-- Projects (Optional) -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Projects</h2>
      <div class="border-l-2 border-gray-200 pl-4">
        <div class="mb-6">
          <div class="flex justify-between gap-4">
            <div>
              <h3 class="text-xl font-semibold">
                <a href="/projects/nuku" class="hover:text-yellow-400">
                  Nuku
                </a>
              </h3>
              <p class="text-gray-300">Local-first health tracker</p>
            </div>
            <p class="text-gray-200">2026</p>
          </div>
          <ul class="list-disc list-inside mt-2 text-gray-400">
            <li>Built a self-hosted family health app for blood pressure, glucose and insulin records</li>
            <li>Implemented a Next.js monorepo with PostgreSQL, Prisma, charts, Excel export and optional Telegram bot</li>
          </ul>
        </div>
        <div class="mb-6">
          <div class="flex justify-between gap-4">
            <div>
              <h3 class="text-xl font-semibold">
                <a href="https://dream-home-pi.vercel.app/" class="hover:text-yellow-400" target="_blank" rel="noopener noreferrer">
                  Dream Home
                </a>
              </h3>
              <p class="text-gray-300">Mortgage and property analysis app</p>
            </div>
            <p class="text-gray-200">2026</p>
          </div>
          <ul class="list-disc list-inside mt-2 text-gray-400">
            <li>Built a Chile-focused home buying tool for affordability simulation, UF values and property comparison</li>
            <li>Implemented geocoding, map views, quotation workflows and property data exports</li>
          </ul>
        </div>
        <div class="mb-6">
          <div class="flex justify-between gap-4">
            <div>
              <h3 class="text-xl font-semibold">AI Memory Vault</h3>
              <p class="text-gray-300">Open source developer tooling</p>
            </div>
            <p class="text-gray-200">2026</p>
          </div>
          <ul class="list-disc list-inside mt-2 text-gray-400">
            <li>Built a Python CLI for extracting, searching, exporting, backing up and restoring AI coding agent sessions</li>
            <li>Designed a portable model for Claude Code, Codex CLI and future agent sources</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Languages -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Languages</h2>
      <ul class="list-disc list-inside text-gray-400 ml-4">
        <li>Spanish (Native)</li>
        <li>French (Intermediate)</li>
        <li>English (Proficient)</li>
      </ul>
    </section>

  </div>
</Layout>
